        "summary": "导入镜像",
        "description": "上传 Docker 镜像 tar 文件并创建后台导入任务。"
      },
      "container_images.export_container_image": {
        "summary": "导出镜像",
        "description": "提交镜像导出任务，完成后可从容器任务接口下载 tar 文件。"
      },
      "container_images.delete_container_image": {
        "summary": "删除镜像",
        "description": "删除当前用户可管理的镜像；镜像被容器使用时会拒绝删除。"
      },
      "container_instances.list_container_instances": {
        "summary": "查询容器列表",
        "description": "按当前用户权限返回可见容器；普通用户仅能查看自己创建的容器。"
      },
      "container_instances.create_container_instance": {
        "summary": "创建容器",
        "description": "基于可见镜像创建容器，默认写入平台归属 labels 并限制危险配置。"
      },
      "container_instances.get_container_logs": {
        "summary": "读取容器日志",
        "description": "按 tail 行数读取指定容器日志。"
      },
      "container_volumes.list_container_volumes": {
        "summary": "查询储存卷列表",
        "description": "查询当前用户可见的 Docker named volumes；普通用户仅能查看自己创建的卷。"
      },
      "container_volumes.create_container_volume": {
        "summary": "创建储存卷",
        "description": "创建一个平台归属的 Docker named volume，用于后续容器挂载。"
      },
      "container_volumes.delete_container_volume": {
        "summary": "删除储存卷",
        "description": "删除当前用户可管理且未被容器使用的储存卷。"
      },
      "container_volumes.prune_container_volumes": {
        "summary": "清理未使用储存卷",
        "description": "清理当前权限范围内未被容器使用的平台储存卷；不会清理外部未打平台标签的卷。"
      },
      "container_jobs.list_container_jobs": {
        "summary": "查询容器任务",
        "description": "查询镜像导入、导出后台任务。"
      },
      "container_jobs.download_container_job": {
        "summary": "下载任务文件",
        "description": "下载成功的镜像导出任务文件。"
      }
