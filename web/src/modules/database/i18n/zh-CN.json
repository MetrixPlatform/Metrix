      },
      "database_data.list_tables": {
        "summary": "查询表列表",
        "description": "查询指定连接和库/schema 下的数据表列表。"
      },
      "database_data.create_table": {
        "summary": "新建表",
        "description": "按字段定义在指定库/schema 中新建数据表。"
      },
      "database_data.list_columns": {
        "summary": "查询字段列表",
        "description": "查询指定数据表的字段、主键、默认值和注释信息。"
      },
      "database_data.table_data": {
        "summary": "查询表数据",
        "description": "分页查询表数据，支持关键字过滤和单字段升降序排序。"
      },
      "database_data.query_database": {
        "summary": "执行 SQL",
        "description": "执行单条 SQL；只读语句需要读取权限，写入语句需要操作权限。"
      },
      "database_data.run_script": {
        "summary": "执行 SQL 脚本",
        "description": "执行多语句 SQL 脚本或已保存脚本，需要数据库操作权限。"
      },
      "database_data.create_row": {
        "summary": "新增数据行",
        "description": "向指定表插入一行数据。"
      },
      "database_data.update_row": {
        "summary": "更新数据行",
        "description": "按主键或定位键更新指定表中的一行数据。"
      },
      "database_data.delete_row": {
        "summary": "删除数据行",
        "description": "按主键或定位键删除指定表中的一行数据。"
      },
      "database_data.table_detail": {
        "summary": "查询表结构",
        "description": "查询指定表的字段和主键信息。"
      },
      "database_data.delete_table": {
        "summary": "删除表",
        "description": "删除指定数据表及其数据，需要数据库操作权限。"
      },
      "database_data.alter_table": {
        "summary": "修改表结构",
        "description": "修改指定表的字段结构。"
      },
      "database_data.rename_table": {
        "summary": "重命名表",
        "description": "重命名指定数据表。"
      },
      "database_data.truncate_table": {
        "summary": "清空表",
        "description": "清空指定数据表的数据并保留表结构。"
      },
      "database_data.alter_schema": {
        "summary": "修改库选项",
        "description": "修改指定库/schema 的字符集或排序规则等选项。"
      },
      "database_data.delete_schema": {
        "summary": "删除库",
        "description": "删除指定库/schema 及其中所有对象。"
      },
      "database_transfer_jobs.submit_export": {
        "summary": "提交数据库导出任务",
        "description": "提交异步数据库导出任务，支持表、查询结果和多查询结果导出。"
      },
      "database_transfer_jobs.submit_import": {
        "summary": "提交数据库导入任务",
        "description": "上传文件并提交异步数据库导入任务，支持 CSV、XLSX、SQLite 和 SQL。"
      },
      "database_transfer_jobs.list_database_transfer_jobs": {
        "summary": "查询数据库任务",
        "description": "分页查询数据库任务，支持关键字、连接、类型、状态、创建人和创建时间排序。"
      },
      "database_transfer_jobs.database_transfer_job_download_count": {
        "summary": "查询未下载导出任务数量",
        "description": "查询当前用户已完成但未下载的数据库导出任务数量，可按数据库连接过滤。"
      },
      "database_transfer_jobs.get_database_transfer_job": {
        "summary": "查询数据库任务详情",
        "description": "查询指定数据库任务的状态、文件、行数和过期时间。"
      },
      "database_transfer_jobs.delete_database_transfer_job": {
        "summary": "删除数据库任务",
        "description": "删除指定数据库任务及其文件。"
      },
      "database_transfer_jobs.download_database_transfer_job": {
        "summary": "下载数据库导出文件",
        "description": "下载已完成的数据库导出任务文件，下载完成后文件会被清理并标记为已下载。"
      }
    },
