{
  "name": "metrix-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "typecheck": "vue-tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:smoke": "node scripts/smoke.mjs",
    "test:regression:install": "playwright install chromium",
    "test:regression": "playwright test",
    "verify": "npm run test:smoke && npm run build && npm run test:regression"
  },
  "dependencies": {
    "@vicons/fluent": "^0.13.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "monaco-editor": "^0.55.1",
    "naive-ui": "^2.43.1",
    "vue": "^3.5.22",
    "vue-i18n": "^11.4.4",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@iconify-json/vscode-icons": "^1.2.58",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.1.12",
    "vue-tsc": "^3.1.3"
  }
}
